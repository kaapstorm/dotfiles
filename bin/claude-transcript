#!/usr/bin/env python3
"""
Convert a Claude Code JSONL session to a readable transcript.

Usage:
    claude-transcript [SESSION.jsonl] > output.txt

    # Use most recent session in cwd's project
    claude-transcript

To use as a hook, update `~/.claude/settings.json` with the following:

```json
{
  "hooks": {
    "Stop": [{
      "matcher": "",
      "hooks": [{
        "type": "command",
        "command": "claude-transcript"
      }]
    }],
  // ...
  },
  // ...
}
```

Transcripts will be saved to `~/.claude/transcripts/`.

Caveats:
- User messages containing XML system tags (injected context like
  <system-reminder>) are stripped — they won't appear in the transcript
- Extended thinking blocks (thinking type) are skipped automatically
- Tool calls and results are skipped
- If a user message precedes only tool calls with no text response
  following, it'll be silently dropped

"""
import json, re, sys
from datetime import date
from pathlib import Path


def get_project_dir():
    slug = str(Path.cwd()).lstrip("/").replace("/", "-")
    return Path.home() / ".claude" / "projects" / f"-{slug}"


def get_project_name(jsonl_path):
    with open(jsonl_path) as f:
        for line in f:
            obj = json.loads(line)
            if obj.get("type") == "system":
                cwd = obj.get("cwd", "")
                if cwd:
                    return Path(cwd).name
    return jsonl_path.parent.name.lstrip("-")


def format_transcript(jsonl_path):
    lines = []
    pending_user = None
    with open(jsonl_path) as f:
        for raw in f:
            obj = json.loads(raw)
            t, is_meta = obj.get("type"), obj.get("isMeta", False)
            if t == "user" and not is_meta:
                content = obj.get("message", {}).get("content", "")
                if (
                    isinstance(content, str)
                    and not re.match(
                        r"^\s*<(local-command|command-name|system-reminder)",
                        content,
                    )
                ):
                    text = re.sub(
                        r"<[a-z_-]+>[^<]*</[a-z_-]+>\s*",
                        "",
                        content,
                        flags=re.DOTALL,
                    ).strip()
                    if text:
                        pending_user = text
            elif t == "assistant":
                content = obj.get("message", {}).get("content", [])
                text = "\n".join(
                    i.get("text","") for i in content if i.get("type")=="text"
                ).strip()
                if text:
                    if pending_user:
                        lines.append(f"❯ {pending_user}\n")
                        pending_user = None
                    lines.append(f"● {text}\n")
    return "\n".join(lines)


if len(sys.argv) > 1:
    path = Path(sys.argv[1])
elif not sys.stdin.isatty():
    # Called as a Stop hook: stdin is JSON with session_id and transcript_path
    hook_input = json.load(sys.stdin)
    session_id = hook_input.get("session_id", "unknown")
    path = Path(hook_input["transcript_path"])
    project = get_project_name(path)
    out_dir = Path.home() / ".claude" / "transcripts"
    out_dir.mkdir(exist_ok=True)
    out_file = out_dir / f"{date.today()}_{project}_{session_id}.txt"
    out_file.write_text(format_transcript(path))
    sys.exit(0)
else:
    d = get_project_dir()
    path = max(d.glob("*.jsonl"), key=lambda p: p.stat().st_mtime)
    print(f"Using: {path}", file=sys.stderr)


print(format_transcript(path))
